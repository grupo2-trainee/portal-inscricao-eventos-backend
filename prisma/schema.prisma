// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id     Int    @id @default(autoincrement())
  nome   String 
  email  String @unique
  senha  String
  inscricoesEvento    InscricaoEvento[]
  inscricoesAtividade InscricaoAtividade[]
  refreshTokens   RefreshTokenCliente[]
}

model Administrador {
  id     Int    @id @default(autoincrement())
  nome   String
  email  String @unique
  senha  String
  eventos Evento[]
  refreshTokens   RefreshTokenAdmin[]
}

enum categoriaEvento{
  academico
  cientifico
  corporativo
  curso
  entretenimento
  religioso
  esportivo
  exibicao
  networking
  outro
}

enum tipoEvento{
  online
  presencial
  hibrido
}

model Evento {
  id                  Int       @id @default(autoincrement())
  idAdmin             Int
  nome                String
  descricao           String
  dataInicio          DateTime
  dataFim             DateTime
  quantidadeInscritos Int
  cidade              String
  categoria           categoriaEvento
  tipo                tipoEvento
  imagemURL           String
  administrador       Administrador @relation(fields: [idAdmin], references: [id], onDelete: Cascade)
  atividades          Atividade[]
  inscricoes          InscricaoEvento[]
}

model Atividade {
  id                  Int       @id @default(autoincrement())
  idEvento            Int
  nome                String
  descricao           String
  dataInicio          DateTime
  dataFim             DateTime
  maximoInscritos     Int
  quantidadeInscritos Int
  localizacao         String
  evento              Evento     @relation(fields: [idEvento], references: [id], onDelete: Cascade)
  inscricoes          InscricaoAtividade[]
}

model InscricaoEvento {
  id         Int     @id @default(autoincrement())
  idCliente  Int
  idEvento   Int
  cliente    Cliente @relation(fields: [idCliente], references: [id], onDelete: Cascade)
  evento     Evento  @relation(fields: [idEvento], references: [id], onDelete: Cascade)
}

model InscricaoAtividade {
  id         Int        @id @default(autoincrement())
  idCliente  Int
  idAtividade Int
  cliente    Cliente     @relation(fields: [idCliente], references: [id], onDelete: Cascade)
  atividade  Atividade   @relation(fields: [idAtividade], references: [id], onDelete: Cascade)
}

model RefreshTokenAdmin {
  id        Int    @id @default(autoincrement())
  idUsuario Int
  token     String @unique
  administrador Administrador   @relation(fields: [idUsuario], references: [id], onDelete: Cascade)
}

model RefreshTokenCliente {
  id        Int    @id @default(autoincrement())
  idUsuario Int
  token     String @unique
  cliente   Cliente   @relation(fields: [idUsuario], references: [id], onDelete: Cascade)
}

